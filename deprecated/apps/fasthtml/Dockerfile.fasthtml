# Single-stage Dockerfile for Skaffold file sync. Mirrors apps/fastapi/Dockerfile
# pattern: uv for fast deps, python:3.13-slim base, uvicorn entrypoint.
FROM python:3.13-slim

# Copy uv binary from official image
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# UV optimization flags (same as fastapi)
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never

WORKDIR /app

# Minimal runtime deps. fasthtml has no native extensions — slim is enough.
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

# Copy dependency files first (for layer caching)
COPY pyproject.toml ./

# Install dependencies into a project-local venv at /app/.venv
RUN --mount=type=cache,target=/root/.cache/uv \
    uv lock && \
    uv sync --frozen --no-install-project --no-dev

# Copy application code
COPY . /app

# Use the venv's Python on PATH
ENV PATH="/app/.venv/bin:$PATH"

EXPOSE 3000

ENTRYPOINT ["/bin/bash", "/app/entrypoint.sh"]
