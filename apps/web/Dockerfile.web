# Single-stage Dockerfile for Skaffold file sync with hot-reload
FROM golang:1.23-alpine

# Install dependencies
RUN apk add --no-cache git bash

# Install Air for hot-reload (pinned to version compatible with Go 1.23)
RUN go install github.com/air-verse/air@v1.61.7

# Install Templ (pinned version)
RUN go install github.com/a-h/templ/cmd/templ@v0.2.793

WORKDIR /app

# Copy application code
COPY . /app

# Generate templ files first (creates _templ.go files)
RUN templ generate

# Download dependencies and generate go.sum
RUN go mod tidy

# Build the application (for initial startup)
RUN go build -o /app/server .

EXPOSE 3000

ENTRYPOINT ["/bin/bash", "/app/entrypoint.sh"]
