# Single-stage Dockerfile for Skaffold file sync
FROM golang:1.23-bookworm

WORKDIR /app

# Install templ CLI and system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends procps curl && \
    rm -rf /var/lib/apt/lists/* && \
    go install github.com/a-h/templ/cmd/templ@v0.3.865 && \
    go install github.com/air-verse/air@latest

# Copy dependency files first (for layer caching)
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy application code
COPY . /app

# Generate templ files and build
RUN templ generate && \
    go build -o /app/server ./cmd/server

# Create logs directory
RUN mkdir -p /app/logs

EXPOSE 3000

ENTRYPOINT ["/bin/bash", "/app/entrypoint.sh"]
