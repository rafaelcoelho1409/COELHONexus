package components

templ HomePage() {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<meta name="theme-color" content="#0a0a0f"/>
		<meta name="description" content="AI-powered YouTube Content Search & Knowledge Graph"/>
		<title>COELHO Nexus — AI YouTube Intelligence</title>
		<link rel="manifest" href="/manifest.json"/>
		<link rel="icon" href="/static/icons/icon-192.png"/>
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daisyui@4.12.23/dist/full.min.css"/>
		<script src="https://cdn.tailwindcss.com"></script>
		<script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
		<link rel="stylesheet" href="/static/css/app.css"/>
	</head>
	<body class="bg-base-100 min-h-screen flex flex-col">
		@Navbar("")
		<main class="flex-1">
			<!-- Hero -->
			<section class="relative overflow-hidden py-24 px-4">
				<!-- Ambient orbs -->
				<div class="absolute inset-0 pointer-events-none">
					<div class="orb orb-1"></div>
					<div class="orb orb-2"></div>
					<div class="orb orb-3"></div>
				</div>
				<div class="relative max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
					<div>
						<div class="badge badge-outline badge-primary mb-6 gap-2 py-3 px-4">
							<span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
							AI-Powered Knowledge Graph
						</div>
						<h1 class="text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6">
							Turn YouTube Into
							<span class="gradient-text block">Intelligence</span>
						</h1>
						<p class="text-lg text-base-content/60 max-w-lg mb-10 leading-relaxed">
							Extract insights, map relationships, and query knowledge from any YouTube video, channel, or playlist using autonomous AI agents.
						</p>
						<div class="flex flex-wrap gap-4">
							<a href="/search" class="btn btn-primary btn-lg gap-2">
								Start Searching
								<svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
							</a>
							<a href="https://github.com/rafaelcoelho1409/YouTubeContentSearch" class="btn btn-outline btn-lg" target="_blank" rel="noopener">
								View on GitHub
							</a>
						</div>
					</div>
					<!-- Knowledge graph visual -->
					<div class="hidden lg:flex justify-center">
						<div class="card bg-base-200/50 backdrop-blur border border-base-300 w-72 h-72 items-center justify-center relative overflow-hidden">
							<div class="graph-node node-center">YT</div>
							<div class="graph-node node-1">AI</div>
							<div class="graph-node node-2">NLP</div>
							<div class="graph-node node-3">KG</div>
							<div class="graph-node node-4">LLM</div>
							<svg class="absolute inset-0 w-full h-full" viewBox="0 0 300 300">
								<defs>
									<linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
										<stop offset="0%" style="stop-color:#6c63ff"/>
										<stop offset="100%" style="stop-color:#00d4ff"/>
									</linearGradient>
								</defs>
								<line x1="150" y1="150" x2="240" y2="80" stroke="url(#lineGrad)" stroke-width="1.5" opacity="0.5"/>
								<line x1="150" y1="150" x2="60" y2="80" stroke="url(#lineGrad)" stroke-width="1.5" opacity="0.5"/>
								<line x1="150" y1="150" x2="240" y2="220" stroke="url(#lineGrad)" stroke-width="1.5" opacity="0.5"/>
								<line x1="150" y1="150" x2="60" y2="220" stroke="url(#lineGrad)" stroke-width="1.5" opacity="0.5"/>
							</svg>
						</div>
					</div>
				</div>
			</section>

			<!-- Feature Cards -->
			<section class="py-20 px-4 max-w-6xl mx-auto">
				<div class="text-center mb-12">
					<h2 class="text-4xl font-bold tracking-tight mb-3">Four Modes of Intelligence</h2>
					<p class="text-base-content/60">Choose how you want to explore YouTube content</p>
				</div>
				<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
					@FeatureCard("Search", "🔍", "/search", "Autonomous AI agents search videos based on your context, filters, and preferences.", "primary")
					@FeatureCard("Video", "▶", "/video", "Extract deep insights, entities, and knowledge graphs from any specific video.", "info")
					@FeatureCard("Channel", "📡", "/channel", "Analyze an entire channel's transcriptions to map topics and knowledge.", "success")
					@FeatureCard("Playlist", "🎵", "/playlist", "Process full playlists and build a unified knowledge graph from all content.", "warning")
				</div>
			</section>

			<!-- Tech Stack -->
			<section class="py-16 px-4 max-w-6xl mx-auto">
				<div class="text-center mb-10">
					<h2 class="text-3xl font-bold tracking-tight">Built With Modern Tech</h2>
				</div>
				<div class="flex flex-wrap justify-center gap-3">
					@TechBadge("Go", "Backend")
					@TechBadge("Templ", "Templating")
					@TechBadge("HTMX", "Interactivity")
					@TechBadge("FastAPI", "AI API")
					@TechBadge("LangChain", "LLM Agents")
					@TechBadge("Neo4j", "Knowledge Graph")
					@TechBadge("Groq", "Inference")
					@TechBadge("Kubernetes", "Orchestration")
				</div>
			</section>
		</main>
		@Footer()
	</body>
	</html>
}

templ FeatureCard(title string, icon string, href string, description string, color string) {
	<a href={ templ.SafeURL(href) } class="card bg-base-200 border border-base-300 hover:border-primary hover:-translate-y-1 transition-all duration-200 hover:shadow-lg hover:shadow-primary/10">
		<div class="card-body gap-4">
			<div class={ "text-3xl w-12 h-12 rounded-xl flex items-center justify-center bg-" + color + "/10" }>
				{ icon }
			</div>
			<h3 class="card-title text-base">{ title }</h3>
			<p class="text-sm text-base-content/60 leading-relaxed">{ description }</p>
			<div class="card-actions">
				<span class="text-primary text-sm font-medium">Explore →</span>
			</div>
		</div>
	</a>
}

templ TechBadge(name string, role string) {
	<div class="badge badge-outline py-4 px-4 gap-2 flex flex-col h-auto">
		<span class="font-bold text-sm">{ name }</span>
		<span class="text-xs opacity-50 uppercase tracking-wider">{ role }</span>
	</div>
}
