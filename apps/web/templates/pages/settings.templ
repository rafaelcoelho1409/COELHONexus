package pages

import (
	"coelhonexus-web/config"
	"fmt"
)

templ Settings() {
	@SettingsPage(config.Providers, config.GetLLMSettings(), config.GetCachedModels())
}

templ SettingsPage(providers []config.Provider, settings config.LLMSettings, models []config.Option) {
	<div class="page settings-page">
		<header class="page-header">
			<h1>Settings</h1>
			<p class="page-subtitle">Configure LLM and application settings</p>
		</header>
		<div class="settings-grid">
			<!-- LLM Configuration -->
			<div class="card span-2">
				<h2 class="card-title">LLM Configuration</h2>
				<form id="llm-form" hx-post="/api/settings/llm" hx-target="#settings-status" hx-swap="innerHTML">
					<div class="form-group">
						<label class="form-label">Provider</label>
						<select name="provider" id="provider-select" class="form-select">
							for _, p := range providers {
								if p.ID == settings.Provider {
									<option value={ p.ID } selected>{ p.Name }</option>
								} else {
									<option value={ p.ID }>{ p.Name }</option>
								}
							}
						</select>
					</div>
					<div class="form-group">
						<label class="form-label">API Key</label>
						<div class="input-with-action">
							<input
								type="password"
								name="api_key"
								id="api-key-input"
								class="form-input"
								placeholder={ providers[0].APIKeyHint }
								value={ settings.APIKey }
							/>
							<button
								type="button"
								class="btn btn-outline btn-sm"
								hx-post="/api/settings/models/refresh"
								hx-target="#model-list"
								hx-swap="innerHTML"
								hx-include="#api-key-input,#provider-select"
							>
								Fetch Models
							</button>
						</div>
						<p class="form-hint">
							Enter your API key from
							<a href={ templ.SafeURL(providers[0].ModelsURL) } target="_blank" class="link">{ providers[0].ModelsURL }</a>
						</p>
					</div>
					<div class="form-group">
						<label class="form-label">Model</label>
						<select name="model" id="model-list" class="form-select">
							for _, m := range models {
								if m.Value == settings.Model {
									<option value={ m.Value } selected>{ m.Label }</option>
								} else {
									<option value={ m.Value }>{ m.Label }</option>
								}
							}
						</select>
					</div>
					<div class="form-group">
						<label class="form-label">Temperature: <span id="temp-value">{ fmt.Sprintf("%.2f", settings.Temperature) }</span></label>
						<input
							type="range"
							name="temperature"
							class="form-range"
							min="0"
							max="1"
							step="0.01"
							value={ fmt.Sprintf("%.2f", settings.Temperature) }
							oninput="document.getElementById('temp-value').textContent = parseFloat(this.value).toFixed(2)"
						/>
						<p class="form-hint">0 = deterministic, 1 = creative</p>
					</div>
					<div class="form-actions">
						<button type="submit" class="btn btn-primary">Save Configuration</button>
					</div>
					<div id="settings-status"></div>
				</form>
			</div>
			<!-- Neo4j Configuration -->
			<div class="card">
				<h2 class="card-title">Neo4j Connection</h2>
				<form hx-post="/api/settings/neo4j" hx-target="#neo4j-status" hx-swap="innerHTML">
					<div class="form-group">
						<label class="form-label">URI</label>
						<input type="text" name="neo4j_uri" class="form-input" placeholder="bolt://localhost:7687"/>
					</div>
					<div class="form-group">
						<label class="form-label">Username</label>
						<input type="text" name="neo4j_user" class="form-input" placeholder="neo4j"/>
					</div>
					<div class="form-group">
						<label class="form-label">Password</label>
						<input type="password" name="neo4j_password" class="form-input"/>
					</div>
					<div class="form-actions">
						<button type="submit" class="btn btn-primary btn-sm">Save</button>
						<button type="button" class="btn btn-outline btn-sm" hx-post="/api/settings/neo4j/test" hx-target="#neo4j-status">Test</button>
					</div>
					<div id="neo4j-status"></div>
				</form>
			</div>
			<!-- Search Configuration -->
			<div class="card">
				<h2 class="card-title">Search Settings</h2>
				<form hx-post="/api/settings/search" hx-target="#search-status" hx-swap="innerHTML">
					<div class="form-group">
						<label class="form-label">Max Videos</label>
						<input type="number" name="max_videos" class="form-input" value="5" min="1" max="50"/>
					</div>
					<div class="form-group">
						<label class="form-label">Chunk Size</label>
						<input type="number" name="chunk_size" class="form-input" value="512" min="128" max="2048"/>
						<p class="form-hint">Tokens per document chunk</p>
					</div>
					<div class="form-group">
						<label class="form-label">Chunk Overlap</label>
						<input type="number" name="chunk_overlap" class="form-input" value="24" min="0" max="256"/>
					</div>
					<div class="form-actions">
						<button type="submit" class="btn btn-primary btn-sm">Save</button>
					</div>
					<div id="search-status"></div>
				</form>
			</div>
		</div>
	</div>
}

templ ModelOptions(models []config.Option, selectedModel string) {
	for _, m := range models {
		if m.Value == selectedModel {
			<option value={ m.Value } selected>{ m.Label }</option>
		} else {
			<option value={ m.Value }>{ m.Label }</option>
		}
	}
}

templ ModelsFetchError(message string) {
	<option value="" disabled selected>{ message }</option>
}
