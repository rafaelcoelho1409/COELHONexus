    "otel",
    "lgtm"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "links": [
    {
      "title": "DD Pipeline",
      "type": "link",
      "url": "/d/coelhonexus-dd-pipeline",
      "targetBlank": false
    },
    {
      "title": "YCS Ask",
      "type": "link",
      "url": "/d/coelhonexus-ycs-retrieval",
      "targetBlank": false
    },
    {
      "title": "RR Scan",
      "type": "link",
      "url": "/d/coelhonexus-rr-digests",
      "targetBlank": false
    },
    {
      "title": "LLM Rotator",
      "type": "link",
      "url": "/d/coelhonexus-rotator-red",
      "targetBlank": false
    },
    {
      "title": "Service Topology",
      "type": "link",
      "url": "/d/coelhonexus-service-topology",
