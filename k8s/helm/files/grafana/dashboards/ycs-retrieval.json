{
  "title": "COELHO Nexus - YCS Ask \u2014 Retrieval + Answer Health",
  "uid": "coelhonexus-ycs-retrieval",
  "tags": [
    "coelhonexus",
    "ycs",
    "ask",
    "retrieval",
    "otel",
    "mimir"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/coelhonexus-overview",
      "targetBlank": false
    },
    {
      "title": "DD Pipeline",
      "type": "link",
      "url": "/d/coelhonexus-dd-pipeline",
      "targetBlank": false
    },
    {
      "title": "RR Scan",
      "type": "link",
      "url": "/d/coelhonexus-rr-digests",
      "targetBlank": false
    },
    {
      "title": "LLM Rotator",
      "type": "link",
      "url": "/d/coelhonexus-rotator-red",
      "targetBlank": false
    },
    {
      "title": "Service Topology",
      "type": "link",
      "url": "/d/coelhonexus-service-topology",
      "targetBlank": false
    },
    {
      "title": "Investigations",
      "type": "link",
      "url": "/d/coelhonexus-investigations",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "mode",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "mimir"
        },
        "query": "label_values(ycs_ask_run_total, mode)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Ask outcomes observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (outcome) (max_over_time(ycs_ask_run_total{mode=~\"$mode\"}[24h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ask duration (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ycs_ask_run_duration_seconds_bucket{mode=~\"$mode\"}[30m])))",
          "exemplar": true,
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ycs_ask_run_duration_seconds_bucket{mode=~\"$mode\"}[30m])))",
          "exemplar": true,
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Grounded answers observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(max_over_time(ycs_grounded_total{mode=~\"$mode\"}[24h]))",
          "legendFormat": "grounded"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Retrieved docs per ask (mean)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(ycs_retrieved_docs_sum[30m])) / sum by (mode) (rate(ycs_retrieved_docs_count[30m]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Graded docs per ask (mean)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(ycs_graded_docs_sum[30m])) / sum by (mode) (rate(ycs_graded_docs_count[30m]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Citation count (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ycs_citation_count_bucket{mode=~\"$mode\"}[30m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ycs_citation_count_bucket{mode=~\"$mode\"}[30m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Query rewrites observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum(max_over_time(ycs_rewrite_total[24h]))",
          "legendFormat": "rewrites"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Deep sub-questions observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum by (outcome) (max_over_time(ycs_subquestion_total[24h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Ask run summary by route / mode / outcome",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (route, mode, outcome) (max_over_time(ycs_ask_run_total{mode=~\"$mode\"}[24h]))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Recent YCS ask error logs",
      "description": "FastAPI and Celery log lines most likely to explain bad or stuck YCS asks.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{namespace=~\"coelhonexus.*\",service_name=~\"coelhonexus-fastapi|coelhonexus-celery\"} |~ \"(?i)(ycs|youtube|ask|search|qdrant|neo4j|error|exception|traceback|failed)\" | regexp \"(?P<trace_id>(?i)trace_id=[0-9a-f]{32})\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "YCS ask log rate by level",
      "description": "5-minute rolling rate of YCS ask log events by severity.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 27
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (detected_level) (count_over_time({namespace=~\"coelhonexus.*\",service_name=~\"coelhonexus-fastapi|coelhonexus-celery\"} |~ \"(?i)(ycs|ask|retrieval|qdrant|neo4j)\" [5m]))",
          "legendFormat": "{{detected_level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E02F44",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3274D9",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}