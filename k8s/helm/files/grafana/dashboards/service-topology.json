{
  "title": "COELHO Nexus - Service Topology",
  "uid": "coelhonexus-service-topology",
  "tags": [
    "coelhonexus",
    "topology",
    "service-graph",
    "tempo",
    "mimir",
    "lgtm"
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/coelhonexus-overview",
      "targetBlank": false
    },
    {
      "title": "DD Pipeline",
      "type": "link",
      "url": "/d/coelhonexus-dd-pipeline",
      "targetBlank": false
    },
    {
      "title": "YCS Ask",
      "type": "link",
      "url": "/d/coelhonexus-ycs-retrieval",
      "targetBlank": false
    },
    {
      "title": "RR Scan",
      "type": "link",
      "url": "/d/coelhonexus-rr-digests",
      "targetBlank": false
    },
    {
      "title": "Investigations",
      "type": "link",
      "url": "/d/coelhonexus-investigations",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "How to use this dashboard",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "This dashboard is backed by Tempo service-graph metrics already written to Mimir by Alloy. Use it to spot the busiest and slowest edges first. For request-level investigation, jump into the app dashboards and then drill into Tempo traces; Tempo is already provisioned with trace-to-logs and trace-to-metrics links."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Top request-rate edges",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "topk(15, sum by (client, server) (rate(traces_service_graph_request_total[30m])))",
          "legendFormat": "{{client}} -> {{server}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Top failed edges",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "topk(15, sum by (client, server) (rate(traces_service_graph_request_failed_total[30m])))",
          "legendFormat": "{{client}} -> {{server}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Client latency p95 by edge",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (client, server, le) (rate(traces_service_graph_request_client_seconds_bucket[30m]))))",
          "legendFormat": "{{client}} -> {{server}}",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Server latency p95 by edge",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (client, server, le) (rate(traces_service_graph_request_server_seconds_bucket[30m]))))",
          "legendFormat": "{{client}} -> {{server}}",
          "exemplar": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Observed service edges (24h)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "expr": "sum by (client, server) (max_over_time(traces_service_graph_request_total[24h]))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "traces",
      "title": "Cross-service error traces",
      "description": "Error-status spans across all COELHO Nexus services. Pairs with the service-graph edge metrics above \u2014 when an edge shows high failure rate, drill into traces here to see the root cause span.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name=~\"coelhonexus.*\" && status=error }",
          "limit": 20,
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "options": {
        "dedupStrategy": "none"
      }
    }
  ]
}