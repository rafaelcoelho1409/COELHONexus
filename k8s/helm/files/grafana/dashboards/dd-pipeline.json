{
  "title": "COELHO Nexus - DD Pipeline \u2014 Planner + Study Health",
  "uid": "coelhonexus-dd-pipeline",
  "tags": [
    "coelhonexus",
    "dd",
    "planner",
    "study",
    "otel",
    "mimir"
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/coelhonexus-overview",
      "targetBlank": false
    },
    {
      "title": "YCS Ask",
      "type": "link",
      "url": "/d/coelhonexus-ycs-retrieval",
      "targetBlank": false
    },
    {
      "title": "RR Scan",
      "type": "link",
      "url": "/d/coelhonexus-rr-digests",
      "targetBlank": false
    },
    {
      "title": "LLM Rotator",
      "type": "link",
      "url": "/d/coelhonexus-rotator-red",
      "targetBlank": false
    },
    {
      "title": "Service Topology",
      "type": "link",
      "url": "/d/coelhonexus-service-topology",
      "targetBlank": false
    },
    {
      "title": "Investigations",
      "type": "link",
      "url": "/d/coelhonexus-investigations",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "framework",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "mimir"
        },
        "query": "label_values(dd_planner_run_total, framework)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Planner outcomes observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (outcome) (max_over_time(dd_planner_run_total{framework=~\"$framework\"}[24h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Planner duration (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(dd_planner_run_duration_seconds_bucket{framework=~\"$framework\"}[30m])))",
          "exemplar": true,
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dd_planner_run_duration_seconds_bucket{framework=~\"$framework\"}[30m])))",
          "exemplar": true,
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Planner chapter count (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(dd_planner_chapter_count_bucket{framework=~\"$framework\"}[30m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dd_planner_chapter_count_bucket{framework=~\"$framework\"}[30m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Studies observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum(max_over_time(dd_study_completion_seconds_count{framework=~\"$framework\"}[24h]))",
          "legendFormat": "studies"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Study completion duration (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(dd_study_completion_seconds_bucket{framework=~\"$framework\"}[1h])))",
          "exemplar": true,
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dd_study_completion_seconds_bucket{framework=~\"$framework\"}[1h])))",
          "exemplar": true,
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Bucket split overflow observed",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum(max_over_time(dd_bucket_split_overflow_total{framework=~\"$framework\"}[24h]))",
          "legendFormat": "events"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Per-dimension grader score (mean)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "sum by (dim) (rate(dd_classical_grader_dim_score_sum{framework=~\"$framework\"}[30m])) / sum by (dim) (rate(dd_classical_grader_dim_score_count{framework=~\"$framework\"}[30m]))",
          "legendFormat": "{{dim}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Audit missing-hash ratio (mean)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(dd_audit_missing_hashes_ratio_sum{framework=~\"$framework\"}[30m]) / rate(dd_audit_missing_hashes_ratio_count{framework=~\"$framework\"}[30m])",
          "legendFormat": "missing ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Classical patches applied by dimension",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (dim) (max_over_time(dd_classical_patch_applied_total{framework=~\"$framework\"}[24h]))",
          "legendFormat": "{{dim}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Refiner iterations to accept (p50 / p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(dd_refiner_iters_to_accept_bucket{framework=~\"$framework\"}[1h])))",
          "exemplar": true,
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(dd_refiner_iters_to_accept_bucket{framework=~\"$framework\"}[1h])))",
          "exemplar": true,
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Recent DD workflow error logs",
      "description": "Planner and synth-oriented error signals from FastAPI and Celery.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{namespace=~\"coelhonexus.*\",service_name=~\"coelhonexus-fastapi|coelhonexus-celery\"} |~ \"(?i)(planner|synth|study|error|exception|traceback|failed)\" | regexp \"(?P<trace_id>(?i)trace_id=[0-9a-f]{32})\" | regexp \"(?P<scan_slug>[a-z][a-z0-9_-]{2,})\" ",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "DD workflow log rate by level",
      "description": "5-minute rolling rate of DD workflow log events by severity. Useful for spotting error bursts during long planner/synth runs.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (detected_level) (count_over_time({namespace=~\"coelhonexus.*\",service_name=~\"coelhonexus-fastapi|coelhonexus-celery\"} |~ \"(?i)(planner|synth|study)\" [5m]))",
          "legendFormat": "{{detected_level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E02F44",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#3274D9",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}