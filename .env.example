# =============================================================================
# COELHO Nexus — application environment template
# =============================================================================
# Copy this file to `.env` (gitignored), edit as needed, then upload it as a
# Kubernetes Secret into the cluster:
#
#   cp .env.example .env
#   ./upload_env_to_k3d.sh .env coelhonexus-dev
#
# upload_env_to_k3d.sh converts each UPPER_UNDERSCORE env var into the
# lower-hyphen key the Helm chart's secretMappings expect (k8s/helm/values.yaml
# `secretMappings` block) and creates `coelhonexus-secret` in the target
# namespace (default `coelhonexus`; pass `coelhonexus-dev` for Skaffold).
#
# Cluster credentials (REDIS/NEO4J/POSTGRES/etc.) MUST match the demo values
# in `infrastructure/env.hcl` — those values are what the data-layer modules
# were provisioned with. Changing the values here without re-provisioning the
# cluster will produce auth failures.
# =============================================================================

# -----------------------------------------------------------------------------
# CLUSTER DATA LAYER — must match infrastructure/env.hcl `demo` block.
# Required for the app to authenticate against the standalone k3d cluster's
# data services. Without these, every Redis/Postgres/Neo4j/MinIO/ES call
# returns 401 or "missing env var" KeyError at app startup.
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=postgres
REDIS_PASSWORD=redis-demo-password
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j-demo-password
# Shared Helm values pin the application-side ES username to `elastic`.
# The standalone Elasticsearch infra converges that built-in user's password
# to the deterministic demo value below so plain `skaffold dev` works.
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=coelhonexus-demo-password
QDRANT_API_KEY=qdrant-demo-api-key

# MinIO is reached via the S3 SDK — uses AWS_* env var names by convention.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# OBSERVABILITY — LangFuse (in-cluster, self-hosted v3).
# Host URL is the in-cluster FQDN — same on COELHO Cloud and coelhonexus.
# Public/secret keys MUST match infrastructure/env.hcl `demo.langfuse_*`.
# -----------------------------------------------------------------------------
LANGFUSE_HOST=http://langfuse-web.langfuse.svc.cluster.local:3000
LANGFUSE_PUBLIC_KEY=lf_pk_demo000000000000000000000000
LANGFUSE_SECRET_KEY=lf_sk_demo000000000000000000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# OPTIONAL — LLM provider API keys (BYOK). The platform boots without these;
# DD/YCS/RR features need at least one provider key to actually do work.
# Prefer entering these via the /settings UI (BYOK store, Fernet-encrypted in
# MinIO) instead — these env-var entries are a one-time bootstrap fallback.
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
SAMBANOVA_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Flower (Celery dashboard) basic auth, only consumed when
# flower.basicAuth.enabled=true in values.yaml. Format: "user:password".
# -----------------------------------------------------------------------------
FLOWER_BASIC_AUTH=
