{
  "title": "LLM Rotator — RED + Cost",
  "uid": "coelhonexus-rotator-red",
  "tags": ["coelhonexus", "rotator", "llm", "gen_ai"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "provider",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "mimir"},
        "query": "label_values(gen_ai_client_operation_duration_seconds_count, gen_ai_system)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "mimir"},
        "query": "label_values(gen_ai_client_operation_duration_seconds_count{gen_ai_system=~\"$provider\"}, gen_ai_request_model)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s) per provider",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (gen_ai_system) (rate(gen_ai_client_operation_duration_seconds_count{gen_ai_system=~\"$provider\", gen_ai_request_model=~\"$model\"}[5m]))",
          "legendFormat": "{{gen_ai_system}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (req/s) per provider",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (gen_ai_system, error_type) (rate(gen_ai_client_operation_duration_seconds_count{gen_ai_system=~\"$provider\", error_type!=\"\"}[5m]))",
          "legendFormat": "{{gen_ai_system}} — {{error_type}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency per provider",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (gen_ai_system, le) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=~\"$provider\", gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p50 {{gen_ai_system}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (gen_ai_system, le) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=~\"$provider\", gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p95 {{gen_ai_system}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (gen_ai_system, le) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_system=~\"$provider\", gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "p99 {{gen_ai_system}}"
        }
      ],
      "options": {"legend": {"showLegend": true}},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Token throughput (input vs output)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\", gen_ai_system=~\"$provider\"}[5m]))",
          "legendFormat": "input tokens/s"
        },
        {
          "expr": "sum(rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\", gen_ai_system=~\"$provider\"}[5m]))",
          "legendFormat": "output tokens/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Cost & tokens by provider (last 1h)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum by (gen_ai_system, gen_ai_request_model) (increase(gen_ai_client_token_usage_total[1h]))",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
